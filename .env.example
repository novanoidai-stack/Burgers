# ========================================
# BURGER-AI Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env or .env.local — add to .gitignore
# ========================================

# ===== APPLICATION =====
NODE_ENV=development
LOG_LEVEL=debug
API_PORT=3000
API_HOST=localhost

# ===== ANTHROPIC / CLAUDE API =====
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ===== TWILIO (Voice / SIP) =====
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_URL=https://your-domain.com/voice/webhook

# ===== DEEPGRAM (Speech-to-Text) =====
DEEPGRAM_API_KEY=your_deepgram_key_here
DEEPGRAM_MODEL=nova-2

# ===== ELEVENLABS (Text-to-Speech) =====
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Default voice (Rachel)

# ===== META WHATSAPP BUSINESS API =====
META_BUSINESS_ACCOUNT_ID=your_business_account_id
META_ACCESS_TOKEN=your_meta_access_token
META_VERIFY_TOKEN=your_verify_token_for_webhooks
META_WEBHOOK_URL=https://your-domain.com/whatsapp/webhook

# ===== SUPABASE (PostgreSQL Database) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here
DATABASE_URL=postgresql://postgres:password@localhost:5432/burger_ai

# ===== STRIPE (Payments) =====
STRIPE_API_KEY=sk_live_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
STRIPE_CURRENCY=EUR

# ===== MERCADO PAGO (Payments - LATAM alternative) =====
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_token
MERCADO_PAGO_PUBLIC_KEY=your_public_key

# ===== DATADOG (Monitoring) =====
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.eu  # or datadoghq.com for US

# ===== RESTAURANT CONFIGURATION =====
RESTAURANT_ID=REST-001
RESTAURANT_NAME=Mi Hamburguería
RESTAURANT_TIMEZONE=Europe/Madrid

# Default menu file (path relative to project root)
MENU_FILE=./data/menu.json

# ===== NGROK (Local Development Tunneling) =====
# Only needed for local testing with real webhooks
NGROK_AUTHTOKEN=your_ngrok_token_here

# ===== DATABASE MIGRATIONS =====
# Run migrations on startup?
RUN_MIGRATIONS_ON_START=false

# ===== CORS & SECURITY =====
CORS_ORIGIN=*
# In production, set to specific domain: https://yourdomain.com

# ===== JWT SECRET (for dashboard authentication) =====
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ===== FEATURE FLAGS =====
# Enable/disable features for testing
FEATURE_VOICE_ENABLED=true
FEATURE_WHATSAPP_ENABLED=true
FEATURE_PAYMENT_ENABLED=true
FEATURE_TPV_ENABLED=false  # Set to true once TPV is integrated

# ===== LATENCY BUDGET TRACKING =====
# Alert if response exceeds threshold (ms)
VOICE_LATENCY_THRESHOLD_MS=1500
STT_LATENCY_THRESHOLD_MS=200
LLM_LATENCY_THRESHOLD_MS=600
TTS_LATENCY_THRESHOLD_MS=400

# ===== CACHE & PERFORMANCE =====
# Redis for session caching (optional, for Sprint 3+)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Menu cache TTL in seconds
MENU_CACHE_TTL=3600

# ===== DEVELOPMENT ONLY =====
# Mock external services (for testing without API keys)
MOCK_DEEPGRAM=false
MOCK_ELEVENLABS=false
MOCK_STRIPE=false
MOCK_TWILIO=false

# Seed database with test data on startup?
SEED_TEST_DATA=false
